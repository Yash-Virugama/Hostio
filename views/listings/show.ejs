<% layout("/layouts/boilerplate") %>


    <div class="row justify-content-center mt-4">
        <div class="col-md-10 col-lg-8 col-11">


            <h3 class="mb-3 d-flex">
                <div><a href="/listings"><i class="fa-solid fa-angle-left me-1"></i></a></div>

                <div>
                    <%= listing.title %>
                </div>
            </h3>
        </div>

        <div class="col-md-10 col-lg-8 col-11 mt-3">
            <div class="card show-card">
                <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing-image">

                <div class="card-body mt-3">
                    <!-- <p class="card-text"> -->

                    <ul class="show-ul">
                        <li>
                            <span class="variables">Owned By: </span>
                            <span class="owner-name">
                                <%= listing.owner.username %>
                            </span>
                        </li>

                        <li>
                            <span class="variables">About: </span>
                            <%= listing.description %>
                        </li>
                        <li>
                            <span class="variables">Price: </span>&#8377; <%= (listing.price ||
                                0).toLocaleString("en-IN") %> / night
                        </li>
                        <li>
                            <span class="variables">Category: </span>
                            <%= listing.category %>

                        </li>
                        <li>
                            <span class="variables">Location: </span>
                            <%= listing.location %>

                        </li>
                        <li>
                            <span class="variables">Country: </span>
                            <%= listing.country %>

                        </li>
                    </ul>
                    <!-- </p> -->
                </div>
            </div>
        </div>
    </div>

    <!-- buttons -->
    <% if(currentUser && currentUser._id.equals(listing.owner._id)){ %>

        <div class="row justify-content-center">
            <div class="col-md-10 col-lg-8 col-11">
                <div class="show-btns row gx-3 mb-3 mt-1">

                    <div class="col-6 d-grid">
                        <a href="/listings/<%= listing._id %>/edit" class="btn red-btn edit-btn">Edit</a>
                    </div>

                    <div class="col-6 d-grid">
                        <form method="post" action="/listings/<%= listing._id %>?_method=DELETE" class="d-grid">
                            <button class="btn btn-dark delete-btn">Delete</button>
                        </form>
                    </div>

                </div>
            </div>
        </div>
        <% } %>

            <div class="row justify-content-center">
                <hr class="col-md-10 col-lg-8 col-11 mt-2">
            </div>

            <!-- MAP SECTION -->
            <div class="row justify-content-center mb-5 mt-2">
                <div class="col-md-10 col-lg-8 col-11">

                    <h4 class="mb-4">Where you'll be</h4>

                    <p id="map-message"></p>
                    <div id="map"></div>

                </div>
            </div>

            <script>
                const mapLocation = "<%= listing.location %>";
            </script>

            <div class="row justify-content-center">
                <hr class="col-md-10 col-lg-8 col-11">
            </div>

            <!-- review-form -->
            <% if(currentUser) { %>
                <div class="row justify-content-center">
                    <div class="col-md-10 col-lg-8 col-11 mt-2">

                        <h4 class="mb-4">Leave a Review</h4>

                        <form method="post" action="/listings/<%= listing._id %>/reviews" class="mb-4 needs-validation "
                            novalidate>

                            <div>
                                <label for="rating" class="form-label mb-2">Rating</label>
                                <fieldset class="starability-slot">

                                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]"
                                        value="1" checked aria-label="No rating." />
                                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                    <label for="first-rate1" title="Terrible">1 star</label>
                                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                    <label for="first-rate2" title="Not good">2 stars</label>
                                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                    <label for="first-rate3" title="Average">3 stars</label>
                                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                    <label for="first-rate4" title="Very good">4 stars</label>
                                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                    <label for="first-rate5" title="Amazing">5 stars</label>
                                </fieldset>
                            </div>

                            <div class="mb-4">
                                <label for="comment" class="form-label">Comments</label>
                                <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control"
                                    required></textarea>
                                <div class="invalid-feedback">Please share your thoughts!</div>
                            </div>

                            <button class="btn red-btn col-12">Submit</button>
                        </form>
                    </div>
                    <hr class="col-md-10 col-lg-8 col-11 mt-2">
                </div>
                <% } %>



                    <!-- show reviews -->
                    <div class="row justify-content-center mt-2">
                        <div class="col-md-10 col-lg-8 col-11">
                            <h4 class="mb-4">All Reviews</h4>

                            <% if(listing.reviews.length===0){ %>

                                <p class="mb-4">No Reviews Available</p>

                                <% } else { %>

                                    <div class="row row-cols-lg-2 row-cols-md-1 row-cols-1 g-4 mb-5">

                                        <% for(review of listing.reviews){ %>

                                            <div class="col">

                                                <div class="card review-card h-100">

                                                    <!-- Header -->
                                                    <div class="card-header review-header">

                                                        <div class="review-user">
                                                            <i class="fa-solid fa-circle-user"></i>

                                                            <span>
                                                                @<%= review.author.username %> 
                                                                    <p class="text-muted small mt-2 review-time mb-0">
                                                                        (<%= review.createdAt.toLocaleDateString("en-IN",
                                                                            { day: 'numeric' , month: 'short' ,
                                                                            year: 'numeric' }) %>)
                                                                    </p>
                                                            </span>
                                                        </div>

                                                        <div class="delete-btn-wrapper">
                                                            <% if(currentUser &&
                                                                currentUser._id.equals(review.author._id)){ %>

                                                                <form method="post"
                                                                    action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">

                                                                    <button class="btn delete-review-btn">

                                                                        <i class="fa-solid fa-trash"></i>

                                                                    </button>

                                                                </form>

                                                                <% } %>
                                                        </div>

                                                    </div>

                                                    <!-- Body -->
                                                    <div class="review-card-body">

                                                        <!-- Rating -->
                                                        <div class="mb-3 ms-2 mt-2 me-2">

                                                            <p class="starability-result"
                                                                data-rating="<%= review.rating %>"></p>

                                                        </div>

                                                        <!-- Comment -->
                                                        <p class="review-comment ms-3 mb-3 me-3">

                                                            <%= review.comment %>

                                                        </p>
                                                    </div>

                                                </div>

                                            </div>

                                            <% } %>

                                    </div>

                                    <% } %>
                        </div>
                    </div>