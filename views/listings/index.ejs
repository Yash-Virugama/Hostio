<% layout("/layouts/boilerplate") %>

    <!-- <h2 class="mt-3 mb-3">All Listings</h2> -->

    <div id="filters">
        <div class="filter-box">

            <a href="/listings" class="filter-link <%= selectedCategory === '' ? 'active-filter' : '' %>">
                <div class="filter">
                    <div><i class="fa-solid fa-globe"></i></div>
                    <p>Anywhere</p>
                </div>
            </a>

            <a href="/listings?category=Rooms"
                class="filter-link <%= selectedCategory === 'Rooms' ? 'active-filter' : '' %>">
                <div class="filter">
                    <div><i class="fa-solid fa-bed"></i></div>
                    <p>Rooms</p>
                </div>
            </a>

            <a href="/listings?category=Iconic Cities"
                class="filter-link <%= selectedCategory === 'Iconic Cities' ? 'active-filter' : '' %>">
                <div class="filter">
                    <div><i class="fa-solid fa-mountain-city"></i></div>
                    <p>Iconic Cities</p>
                </div>
            </a>

            <a href="/listings?category=Mountains"
                class="filter-link <%= selectedCategory === 'Mountains' ? 'active-filter' : '' %>">
                <div class="filter">
                    <div><i class="fa-solid fa-mountain"></i></i></div>
                    <p>Mountains</p>
                </div>
            </a>

            <a href="/listings?category=Castles"
                class="filter-link <%= selectedCategory === 'Castles' ? 'active-filter' : '' %>">
                <div class="filter">
                    <div><i class="fa-brands fa-fort-awesome"></i></div>
                    <p>Castles</p>
                </div>
            </a>

            <a href="/listings?category=Amazing Pools"
                class="filter-link <%= selectedCategory === 'Amazing Pools' ? 'active-filter' : '' %>">
                <div class="filter">
                    <div><i class="fa-solid fa-person-swimming"></i></div>
                    <p>Amazing Pools</p>
                </div>
            </a>

            <a href="/listings?category=Camping"
                class="filter-link <%= selectedCategory === 'Camping' ? 'active-filter' : '' %>">
                <div class="filter">
                    <div><i class="fa-solid fa-campground"></i></div>
                    <p>Camping</p>
                </div>
            </a>

            <a href="/listings?category=Farms"
                class="filter-link <%= selectedCategory === 'Farms' ? 'active-filter' : '' %>">
                <div class="filter">
                    <div><i class="fa-solid fa-cow"></i></div>
                    <p>Farms</p>
                </div>
            </a>

            <a href="/listings?category=Arctic"
                class="filter-link <%= selectedCategory === 'Arctic' ? 'active-filter' : '' %>">
                <div class="filter">
                    <div><i class="fa-regular fa-snowflake"></i></div>
                    <p>Arctic</p>
                </div>
            </a>

            <a href="/listings?category=Others"
                class="filter-link <%= selectedCategory === 'Others' ? 'active-filter' : '' %>">
                <div class="filter">
                    <div><i class="fa-solid fa-ellipsis"></i></div>
                    <p>More</p>
                </div>
            </a>

        </div>

        <div class="tax-toggle">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
                <!-- <label class="form-check-label" for="flexSwitchCheckDefault">Default Total After Taxes</label> -->
                <span>Display Total After Taxes</span>
            </div>
        </div>
    </div>

    <% if (allListings.length> 0) { %>
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-1 mt-4 mx-0">


            <% for(let listing of allListings){ %>

                <a href="/listings/<%= listing._id %>" class="listing-link">

                    <div class="card col">
                        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image"
                            style="height: 20rem;">

                        <div class="card-img-overlay"></div>

                        <div class="card-body">
                            <p class="card-text">
                                <b>
                                    <%= listing.title %>
                                </b>
                                <br>
                                &#8377; <span class="listing-price-display" data-base-price="<%= listing.price || 0 %>">
                                    <%= (listing.price || 0).toLocaleString("en-IN") %>
                                </span> / night
                                <i class="tax-info">(18% GST)</i>
                            </p>
                        </div>
                    </div>
                </a>

                <% } %>
        </div>
        <% } else { %>

            <div class="row justify-content-center mt-5 mb-5">
                <div class="col-md-10 col-lg-6 col-11 text-center">

                    <% if (searchQuery) { %>
                        <i class="fa-solid fa-magnifying-glass fa-3x mb-3 text-muted"></i>
                        <h3>No listings found for "<%= searchQuery %>"</h3>
                        <p>Try checking your spelling or using more general terms.</p>

                        <% } else if (selectedCategory) { %>
                            <i class="fa-solid fa-house-laptop fa-3x mb-3 text-muted"></i>
                            <h3>No listings available in "<%= selectedCategory %>"</h3>
                            <p>Be the first to host a space in this category!</p>

                            <% } else { %>
                                <i class="fa-solid fa-face-frown fa-3x mb-3 text-muted"></i>
                                <h3>No listings found</h3>
                                <p>There are currently no properties listed on the platform.</p>
                                <% } %>

                                    <a href="/listings" class="btn red-btn clear-btn mt-2 w-75">Clear All Filters</a>
                </div>
            </div>
            <% } %>